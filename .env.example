# =============================================================================
# PariShiksha — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to git.

# --- Wk10 Required Keys ---
OPENAI_API_KEY=          # For text-embedding-3-small embeddings
ANTHROPIC_API_KEY=       # For claude-haiku-4-5 generation

# --- Wk9 Legacy (optional) ---
GEMINI_API_KEY=          # For Gemini generation (Wk9 pipeline)
HF_TOKEN=               # For Hugging Face models (optional)

# --- Logging ---
LOG_LEVEL=INFO
