# =============================================================================
# PariShiksha — Environment Configuration
# Copy this file to .env and fill in your actual keys
# =============================================================================

# Google Gemini API Key (for decoder-only generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face Token (for gated models, optional)
HF_TOKEN=your_hugging_face_token_here

# OpenAI API Key (optional, for comparison)
OPENAI_API_KEY=your_openai_api_key_here

# Logging level
LOG_LEVEL=INFO

# Data paths (override defaults if needed)
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
